    mv "$name-tmp/library-template" "$name"
    rm -rf "$name-tmp"
    
    cd "$name" || return
    rm -rf .git && git init
    
    local system_name="${name//-/_}"
    mv "src/template_placeholder" "src/$system_name"
    
    if [[ "$OSTYPE" == "darwin"* ]]; then
        sed -i '' "s/template-placeholder/$name/g" pyproject.toml
        sed -i '' "s/template_placeholder/$system_name/g" pyproject.toml src/$system_name/main.py
    else
        sed -i "s/template-placeholder/$name/g" pyproject.toml
        sed -i "s/template_placeholder/$system_name/g" pyproject.toml src/$system_name/main.py
    fi
    echo "🎉 Library project '$name' initialized successfully!"
}
